# ---------------------------------------------------------------------------
# World Cup 2026 Learning Explorer — environment variables
# ---------------------------------------------------------------------------
# The app works fully with the bundled curated data and NO keys at all.
# These variables only switch on OPTIONAL live data.
#
# Copy this file to ".env.local" and set what you want.
# ---------------------------------------------------------------------------

# Turn on LIVE fixtures & scores from the free worldcup26.ir provider.
# "true" = live (with automatic fallback to bundled data if it's unreachable).
# Anything else (or unset) = bundled sample data.
# This is a SERVER-only runtime toggle, so on Vercel you can change it and
# redeploy WITHOUT editing code.
USE_LIVE_DATA=false

# --- Advanced / optional (not required for the worldcup26.ir provider) -------
# If you later wire in a different provider that needs a key/base URL, read
# these inside src/lib/providers/ and src/app/api/matches/route.ts.
API_FOOTBALL_KEY=
WORLD_CUP_API_BASE=
