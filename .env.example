# ---------------------------------------------------------------------------
# World Cup 2026 Learning Explorer — environment variables
# ---------------------------------------------------------------------------
# The app works fully with the bundled curated data and NO keys at all, and
# depends on no external server.
#
# Copy this file to ".env.local" only if you want to wire in your own trusted
# live data provider (see the README, "Using live data").
# ---------------------------------------------------------------------------

# Turn on LIVE mode. Only useful once you've implemented a provider in
# src/app/api/matches/route.ts (fetchLiveMatches). With no provider configured,
# the app safely uses the bundled curated schedule. Server-only runtime toggle.
USE_LIVE_DATA=false

# Optional: a key for whatever trusted provider you wire in (e.g. api-football).
# Read it inside fetchLiveMatches() in the route handler.
API_FOOTBALL_KEY=

# ---------------------------------------------------------------------------
# In-app feedback → GitHub Issues (optional)
# ---------------------------------------------------------------------------
# The "💬 Tell us!" button files a GitHub Issue when someone sends feedback.
# Without a token the button still works but fails softly ("Thanks!") and no
# issue is created. Server-only — never prefix with NEXT_PUBLIC_.

# A fine-grained GitHub Personal Access Token with "Issues: Read & Write" on the
# target repo only. Create at github.com/settings/personal-access-tokens.
GITHUB_FEEDBACK_TOKEN=

# Where feedback issues are filed. Defaults to this project's repo if unset.
GITHUB_FEEDBACK_REPO=VMalafa/world-cup-2026-explorer

# ---------------------------------------------------------------------------
# Wonder illustration generator (authoring-time only — ADR-0004)
# ---------------------------------------------------------------------------
# Only needed to run `npm run gen:wonders`, which creates the Wonders' atlas
# illustrations via the Vercel AI Gateway. NOT used by the live app, which reads
# the committed PNGs in public/wonders (and falls back to emoji). One key on your
# existing Vercel account: https://vercel.com/docs/ai-gateway
AI_GATEWAY_API_KEY=
