# ---------------------------------------------------------------------------
# World Cup 2026 Learning Explorer — environment variables
# ---------------------------------------------------------------------------
# The app works fully with the bundled curated data and NO keys at all.
# These variables only switch on OPTIONAL live data sources.
#
# Copy this file to ".env.local" and fill in any keys you have.
# ---------------------------------------------------------------------------

# Toggle live match/score fetching. "false" (default) uses bundled sample data.
NEXT_PUBLIC_USE_LIVE_DATA=false

# Optional: API-Football (https://www.api-football.com/) free-tier key.
# Only read on the server. Used by /api/matches when live data is enabled.
API_FOOTBALL_KEY=

# Optional: base URL for a World Cup data provider (e.g. https://wc2026api.com).
# Leave blank to skip. Used by /api/matches when live data is enabled.
WORLD_CUP_API_BASE=
